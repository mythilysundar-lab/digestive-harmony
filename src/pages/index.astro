---
---

<html lang="en">
  <head>
    <title>Digestive Harmony | Advancing Hope for IBD</title>
    <meta name="description" content="Digestive Harmony supports individuals and families affected by IBD through education, awareness, support, and research." />
  </head>

  <body>
    <header class="site-header">
      <div class="logo-wrap">
        <img src="/logo.png" alt="Digestive Harmony logo" />
      </div>

      <nav>
        <a class="active" href="/">Home</a>
        <a href="/about">About</a>
        <a href="/resources">Resources</a>
        <a href="/get-involved">Get Involved</a>
        <a href="/contact">Contact</a>
        <a class="donate" href="/donate">Donate</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Awareness | Support | Research</p>
          <h1>Advancing Hope for IBD</h1>
          <div class="line"></div>
          <p>
            Helping patients and families navigate digestive conditions through
            trusted education, community, and compassion.
          </p>

          <div class="buttons">
            <a href="/about">Our Mission</a>
            <a class="outline" href="/resources">Explore Resources</a>
          </div>
        </div>

        <div class="hero-image">
          <img src="/hero-family.png" alt="Family support for digestive health" />
        </div>
      </section>

      <section class="mission">
        <div class="mission-icon">
          <span>DH</span>
        </div>

        <div>
          <h2>Our Mission</h2>
          <p>
            To improve the lives of those affected by inflammatory bowel disease
            through education, support, advocacy, and research.
          </p>
        </div>

        <blockquote>
          You are not alone.<br />
          We are in this together.
        </blockquote>
      </section>

      <section class="focus">
        <h2>Our Focus</h2>
        <div class="small-line"></div>
        <p class="section-intro">
          We believe education can reduce fear, improve confidence, and help
          people take meaningful steps toward better digestive wellness.
        </p>

        <div class="cards">
          <article>
            <div class="circle">01</div>
            <h3>Digestive Disorders</h3>
            <p>Educational resources on IBD, Crohn's disease, ulcerative colitis, IBS, GERD, and celiac disease.</p>
          </article>

          <article>
            <div class="circle">02</div>
            <h3>Nutrition & Lifestyle</h3>
            <p>Practical guidance for gut-friendly food choices, wellness habits, and daily digestive support.</p>
          </article>

          <article>
            <div class="circle">03</div>
            <h3>Patient Education</h3>
            <p>Clear articles, guides, and resources designed to make digestive health easier to understand.</p>
          </article>

          <article>
            <div class="circle">04</div>
            <h3>Community Support</h3>
            <p>Helping patients, caregivers, and families feel connected, informed, and supported.</p>
          </article>
        </div>
      </section>

      <section class="cta">
        <div>
          <h2>Building a healthier, more informed community.</h2>
          <p>
            Whether you are a patient, caregiver, volunteer, or healthcare advocate,
            Digestive Harmony welcomes you.
          </p>
        </div>
        <a href="/get-involved">Get Involved</a>
      </section>
    </main>

    <footer>
      <div>
        <img src="/logo.png" alt="Digestive Harmony logo" />
      </div>

      <div>
        <h4>Quick Links</h4>
        <a href="/about">About Us</a>
        <a href="/resources">Resources</a>
        <a href="/get-involved">Get Involved</a>
        <a href="/contact">Contact Us</a>
      </div>

      <div>
        <h4>Resources</h4>
        <a href="/resources">IBD Basics</a>
        <a href="/resources">Nutrition</a>
        <a href="/resources">Patient Education</a>
        <a href="/resources">Support & Community</a>
      </div>

      <div>
        <h4>Stay Connected</h4>
        <p>Subscribe for updates, resources, and ways to get involved.</p>
      </div>
    </footer>

    <div class="copyright">
      &copy; 2026 Digestive Harmony. All rights reserved.
    </div>
  </body>
</html>

<style>
  :root {
    --navy: #08294f;
    --purple: #6e42c1;
    --teal: #0698a8;
    --light-teal: #eefcfd;
    --light-purple: #f5efff;
    --text: #102542;
    --muted: #52647a;
    --white: #ffffff;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    color: var(--text);
    background: white;
  }

  a {
    text-decoration: none;
  }

  .site-header {
    height: 138px;
    padding: 18px 6%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: white;
    box-shadow: 0 8px 24px rgba(8, 41, 79, 0.06);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .logo-wrap img {
    width: 225px;
    display: block;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 28px;
    font-weight: 700;
  }

  nav a {
    color: var(--navy);
  }

  nav .active {
    color: var(--purple);
    border-bottom: 3px solid var(--purple);
    padding-bottom: 8px;
  }

  .donate {
    color: white !important;
    padding: 14px 24px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--purple), var(--teal));
  }

  .hero {
    display: grid;
    grid-template-columns: 0.92fr 1.08fr;
    align-items: center;
    min-height: 580px;
    background:
      radial-gradient(circle at 12% 85%, rgba(110, 66, 193, 0.18), transparent 26%),
      linear-gradient(135deg, #ffffff 0%, #fbf7ff 44%, #ecfbfc 100%);
  }

  .hero-copy {
    padding: 70px 6% 70px 12%;
  }

  .eyebrow {
    color: var(--purple);
    font-size: 15px;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(50px, 6vw, 82px);
    line-height: 1.03;
    margin: 20px 0 16px;
    color: var(--navy);
  }

  .line,
  .small-line {
    width: 72px;
    height: 4px;
    border-radius: 99px;
    background: linear-gradient(90deg, var(--purple), var(--teal));
  }

  .hero-copy p:not(.eyebrow) {
    max-width: 570px;
    font-size: 21px;
    line-height: 1.65;
    color: var(--text);
  }

  .buttons {
    margin-top: 30px;
  }

  .buttons a {
    display: inline-block;
    padding: 15px 28px;
    border-radius: 999px;
    color: white;
    font-weight: 800;
    background: linear-gradient(135deg, var(--purple), var(--teal));
    margin-right: 14px;
  }

  .buttons .outline {
    color: var(--teal);
    background: white;
    border: 2px solid var(--teal);
  }

  .hero-image {
    height: 100%;
    overflow: hidden;
    border-bottom-left-radius: 95px;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .mission {
    display: grid;
    grid-template-columns: 130px 1.35fr 1fr;
    align-items: center;
    gap: 36px;
    padding: 46px 8%;
    background: linear-gradient(135deg, #fbf8ff, #effdff);
  }

  .mission-icon {
    width: 105px;
    height: 105px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: white;
    box-shadow: 0 16px 40px rgba(110, 66, 193, 0.14);
  }

  .mission-icon span {
    font-weight: 900;
    font-size: 28px;
    color: var(--teal);
  }

  .mission h2,
  .focus h2 {
    font-size: 36px;
    margin: 0 0 14px;
    color: var(--navy);
  }

  .mission p {
    line-height: 1.7;
    font-size: 17px;
    margin: 0;
  }

  blockquote {
    margin: 0;
    padding-left: 38px;
    border-left: 1px solid rgba(8, 41, 79, 0.16);
    color: var(--teal);
    font-size: 24px;
    font-style: italic;
    line-height: 1.6;
  }

  .focus {
    text-align: center;
    padding: 58px 6% 72px;
  }

  .focus .small-line {
    margin: 12px auto 18px;
  }

  .section-intro {
    max-width: 720px;
    margin: 0 auto 42px;
    color: var(--text);
    line-height: 1.7;
    font-size: 17px;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 26px;
  }

  article {
    background: white;
    border-radius: 24px;
    padding: 38px 28px;
    box-shadow: 0 18px 44px rgba(8, 41, 79, 0.08);
    border: 1px solid #eef1f7;
  }

  .circle {
    width: 76px;
    height: 76px;
    margin: 0 auto 22px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 22px;
    font-weight: 900;
    color: var(--purple);
    background: linear-gradient(135deg, var(--light-purple), var(--light-teal));
  }

  article h3 {
    font-size: 21px;
    color: var(--navy);
    margin-bottom: 14px;
  }

  article p {
    line-height: 1.65;
    color: var(--text);
  }

  .cta {
    margin: 12px 6% 76px;
    padding: 54px;
    border-radius: 30px;
    color: white;
    background: linear-gradient(135deg, var(--purple), var(--teal));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 36px;
    box-shadow: 0 20px 46px rgba(8, 41, 79, 0.14);
  }

  .cta h2 {
    font-size: 36px;
    margin: 0 0 14px;
  }

  .cta p {
    font-size: 17px;
    line-height: 1.6;
    max-width: 660px;
  }

  .cta a {
    background: white;
    color: var(--purple);
    padding: 16px 34px;
    border-radius: 999px;
    font-weight: 900;
    white-space: nowrap;
  }

  footer {
    background: #f8f5ff;
    padding: 44px 6%;
    display: grid;
    grid-template-columns: 1.25fr 1fr 1fr 1.15fr;
    gap: 40px;
  }

  footer img {
    width: 185px;
  }

  footer h4 {
    margin: 0 0 16px;
    color: var(--navy);
  }

  footer a {
    display: block;
    color: var(--text);
    margin: 10px 0;
  }

  footer p {
    color: var(--muted);
    line-height: 1.6;
  }

  .copyright {
    padding: 20px 6%;
    color: var(--navy);
    background: white;
    font-size: 14px;
  }

  @media (max-width: 900px) {
    .site-header {
      height: auto;
      flex-direction: column;
      gap: 18px;
    }

    nav {
      flex-wrap: wrap;
      justify-content: center;
      gap: 14px;
    }

    .hero {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      padding: 52px 7%;
      text-align: center;
    }

    .line {
      margin: auto;
    }

    .hero-image {
      border-bottom-left-radius: 0;
      height: 360px;
    }

    .mission,
    .cards,
    footer {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .mission-icon {
      margin: auto;
    }

    blockquote {
      border-left: none;
      padding-left: 0;
    }

    .cta {
      flex-direction: column;
      text-align: center;
      padding: 40px 24px;
    }
  }
</style>
