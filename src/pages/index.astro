---
---

<html lang="en">
  <head>
    <title>Digestive Harmony | Advancing Hope for IBD</title>
    <meta name="description" content="Digestive Harmony supports individuals and families affected by IBD through education, awareness, support, and research." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <body>
    <header class="site-header">
      <a class="logo-wrap" href="/">
        <img src="/logo.png" alt="Digestive Harmony logo" />
      </a>

      <nav>
        <a class="active" href="/">Home</a>
        <a href="/about">About</a>
        <a href="/resources">Resources</a>
        <a href="/get-involved">Get Involved</a>
        <a href="/contact">Contact</a>
        <a class="donate" href="/donate">Donate</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <img class="decor hero-leaf" src="/leaf-pattern.png" alt="" />
        <img class="decor hero-butterfly" src="/butterfly-icon.png" alt="" />

        <div class="hero-copy">
          <p class="eyebrow">Awareness | Support | Research</p>
          <h1>Advancing Hope for IBD</h1>
          <div class="line"></div>
          <p>
            Helping patients and families navigate digestive conditions through trusted
            education, community, and compassion.
          </p>

          <div class="buttons">
            <a href="/about">Our Mission</a>
            <a class="outline" href="/resources">Explore Resources</a>
          </div>
        </div>

        <div class="hero-image">
          <img src="/hero-family.png" alt="Family support for digestive health" />
        </div>
      </section>

      <section class="mission">
        <img class="decor mission-butterfly" src="/butterfly-icon.png" alt="" />

        <div class="mission-mark">
          <img src="/butterfly-icon.png" alt="" />
        </div>

        <div>
          <h2>Our Mission</h2>
          <p>
            To improve the lives of those affected by inflammatory bowel disease
            through education, support, advocacy, and research.
          </p>
        </div>

        <blockquote>
          You are not alone.<br />
          We are in this together.
        </blockquote>
      </section>

      <section class="focus">
        <h2>Our Focus</h2>
        <div class="small-line"></div>
        <p class="section-intro">
          We believe education can reduce fear, improve confidence, and help people
          take meaningful steps toward better digestive wellness.
        </p>

        <div class="cards">
          <article>
            <div class="circle">IBD</div>
            <h3>Digestive Disorders</h3>
            <p>Educational resources on IBD, Crohn's disease, ulcerative colitis, IBS, GERD, and celiac disease.</p>
          </article>

          <article>
            <div class="circle">NUT</div>
            <h3>Nutrition & Lifestyle</h3>
            <p>Practical guidance for gut-friendly food choices, wellness habits, and daily digestive support.</p>
          </article>

          <article>
            <div class="circle">EDU</div>
            <h3>Patient Education</h3>
            <p>Clear articles, guides, and resources designed to make digestive health easier to understand.</p>
          </article>

          <article>
            <div class="circle">COM</div>
            <h3>Community Support</h3>
            <p>Helping patients, caregivers, and families feel connected, informed, and supported.</p>
          </article>
        </div>
      </section>

      <section class="cta">
        <img class="decor cta-leaf" src="/leaf-pattern.png" alt="" />
        <img class="decor cta-butterfly" src="/butterfly-icon.png" alt="" />

        <div>
          <p class="cta-label">Together for hope</p>
          <h2>Building a healthier, more informed community.</h2>
          <p>
            Whether you are a patient, caregiver, volunteer, or healthcare advocate,
            Digestive Harmony welcomes you.
          </p>
        </div>

        <a href="/get-involved">Get Involved</a>
      </section>
    </main>

    <footer>
      <img class="decor footer-butterfly" src="/butterfly-icon.png" alt="" />

      <div>
        <img class="footer-logo" src="/logo.png" alt="Digestive Harmony logo" />
        <p>A world where everyone affected by IBD can live well and thrive.</p>
      </div>

      <div>
        <h4>Quick Links</h4>
        <a href="/about">About Us</a>
        <a href="/resources">Resources</a>
        <a href="/get-involved">Get Involved</a>
        <a href="/contact">Contact Us</a>
      </div>

      <div>
        <h4>Resources</h4>
        <a href="/resources">IBD Basics</a>
        <a href="/resources">Nutrition</a>
        <a href="/resources">Patient Education</a>
        <a href="/resources">Support & Community</a>
      </div>

      <div>
        <h4>Stay Connected</h4>
        <p>Subscribe for updates, resources, and ways to get involved.</p>
        <div class="email-box">Your email address <span>Submit</span></div>
      </div>
    </footer>

    <div class="copyright">
      &copy; 2026 Digestive Harmony. All rights reserved.
    </div>
  </body>
</html>

<style>
  :root {
    --navy: #08294f;
    --purple: #6e42c1;
    --teal: #0698a8;
    --light-teal: #eefcfd;
    --light-purple: #f5efff;
    --text: #102542;
    --muted: #52647a;
    --white: #ffffff;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: "Inter", Arial, sans-serif;
    color: var(--text);
    background: white;
  }

  a { text-decoration: none; }

  h1, h2 {
    font-family: "Cormorant Garamond", Georgia, serif;
  }

  .site-header {
    min-height: 104px;
    padding: 12px 5.5%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(255,255,255,.97);
    box-shadow: 0 8px 28px rgba(8, 41, 79, 0.06);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .logo-wrap img {
    width: 205px;
    display: block;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 26px;
    font-weight: 700;
  }

  nav a { color: var(--navy); }

  nav .active {
    color: var(--purple);
    border-bottom: 3px solid var(--purple);
    padding-bottom: 8px;
  }

  .donate {
    color: white !important;
    padding: 13px 24px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--purple), var(--teal));
  }

  .decor {
    position: absolute;
    pointer-events: none;
    user-select: none;
  }

  .hero {
    position: relative;
    display: grid;
    grid-template-columns: .95fr 1.05fr;
    align-items: center;
    min-height: 620px;
    overflow: hidden;
    background:
      radial-gradient(circle at 7% 80%, rgba(110,66,193,.17), transparent 30%),
      radial-gradient(circle at 92% 14%, rgba(6,152,168,.15), transparent 32%),
      linear-gradient(135deg, #ffffff 0%, #fbf7ff 45%, #ecfbfc 100%);
  }

  .hero-copy {
    padding: 82px 6% 82px 11%;
    position: relative;
    z-index: 3;
  }

  .eyebrow {
    color: var(--purple);
    font-size: 14px;
    font-weight: 900;
    letter-spacing: .2em;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(60px, 7vw, 96px);
    line-height: .96;
    margin: 18px 0 18px;
    color: var(--navy);
  }

  .line, .small-line {
    width: 78px;
    height: 4px;
    border-radius: 99px;
    background: linear-gradient(90deg, var(--purple), var(--teal));
  }

  .hero-copy p:not(.eyebrow) {
    max-width: 590px;
    font-size: 21px;
    line-height: 1.65;
  }

  .buttons { margin-top: 32px; }

  .buttons a {
    display: inline-block;
    padding: 15px 28px;
    border-radius: 999px;
    color: white;
    font-weight: 800;
    background: linear-gradient(135deg, var(--purple), var(--teal));
    margin-right: 14px;
    box-shadow: 0 14px 30px rgba(6,152,168,.18);
  }

  .buttons .outline {
    color: var(--teal);
    background: white;
    border: 2px solid var(--teal);
    box-shadow: none;
  }

  .hero-image {
    height: 100%;
    overflow: hidden;
    border-bottom-left-radius: 130px;
    box-shadow: -22px 22px 70px rgba(8,41,79,.09);
    position: relative;
    z-index: 2;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-butterfly {
    width: 86px;
    right: 7%;
    top: 82px;
    opacity: .22;
    transform: rotate(12deg);
    z-index: 5;
  }

  .hero-leaf {
    width: 390px;
    left: -95px;
    bottom: -80px;
    opacity: .08;
    z-index: 1;
  }

  .mission {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: 130px 1.35fr 1fr;
    align-items: center;
    gap: 36px;
    padding: 52px 8%;
    background: linear-gradient(135deg, #fbf8ff, #effdff);
  }

  .mission-mark {
    width: 108px;
    height: 108px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: white;
    box-shadow: 0 16px 40px rgba(110,66,193,.14);
    position: relative;
    z-index: 2;
  }

  .mission-mark img {
    width: 62px;
  }

  .mission-butterfly {
    width: 58px;
    right: 11%;
    top: 28px;
    opacity: .14;
  }

  .mission h2, .focus h2 {
    font-size: 42px;
    margin: 0 0 14px;
    color: var(--navy);
  }

  .mission p {
    line-height: 1.7;
    font-size: 17px;
    margin: 0;
  }

  blockquote {
    margin: 0;
    padding-left: 38px;
    border-left: 1px solid rgba(8,41,79,.16);
    color: var(--teal);
    font-size: 24px;
    font-style: italic;
    line-height: 1.6;
    font-family: Georgia, serif;
  }

  .focus {
    text-align: center;
    padding: 66px 6% 82px;
    background: white;
  }

  .focus .small-line {
    margin: 12px auto 18px;
  }

  .section-intro {
    max-width: 720px;
    margin: 0 auto 42px;
    line-height: 1.7;
    font-size: 17px;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 26px;
  }

  article {
    background: white;
    border-radius: 28px;
    padding: 42px 28px;
    box-shadow: 0 20px 48px rgba(8,41,79,.08);
    border: 1px solid #eef1f7;
    transition: transform .3s ease, box-shadow .3s ease;
  }

  article:hover {
    transform: translateY(-7px);
    box-shadow: 0 26px 60px rgba(8,41,79,.12);
  }

  .circle {
    width: 82px;
    height: 82px;
    margin: 0 auto 22px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 18px;
    font-weight: 900;
    color: var(--purple);
    background: linear-gradient(135deg, var(--light-purple), var(--light-teal));
  }

  article h3 {
    font-size: 21px;
    color: var(--navy);
    margin-bottom: 14px;
  }

  article p { line-height: 1.65; }

  .cta {
    position: relative;
    margin: 18px 6% 80px;
    padding: 64px;
    border-radius: 34px;
    color: white;
    background:
      radial-gradient(circle at 86% 35%, rgba(255,255,255,.14), transparent 28%),
      linear-gradient(135deg, var(--purple), var(--teal));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 36px;
    box-shadow: 0 24px 54px rgba(8,41,79,.16);
    overflow: hidden;
  }

  .cta-label {
    text-transform: uppercase;
    letter-spacing: .16em;
    font-size: 13px;
    font-weight: 900;
    opacity: .9;
  }

  .cta h2 {
    font-size: 46px;
    line-height: 1.02;
    margin: 0 0 14px;
  }

  .cta p {
    font-size: 17px;
    line-height: 1.6;
    max-width: 660px;
  }

  .cta a {
    background: white;
    color: var(--purple);
    padding: 17px 36px;
    border-radius: 999px;
    font-weight: 900;
    white-space: nowrap;
    z-index: 2;
  }

  .cta-leaf {
    width: 380px;
    right: -95px;
    bottom: -110px;
    opacity: .15;
  }

  .cta-butterfly {
    width: 70px;
    right: 70px;
    top: 35px;
    opacity: .18;
  }

  footer {
    position: relative;
    overflow: hidden;
    background: #f8f5ff;
    padding: 54px 6%;
    display: grid;
    grid-template-columns: 1.25fr 1fr 1fr 1.15fr;
    gap: 40px;
  }

  .footer-logo { width: 185px; }

  footer h4 {
    margin: 0 0 16px;
    color: var(--navy);
  }

  footer a {
    display: block;
    color: var(--text);
    margin: 10px 0;
  }

  footer p {
    color: var(--muted);
    line-height: 1.6;
  }

  .footer-butterfly {
    width: 78px;
    right: 5%;
    bottom: 24px;
    opacity: .12;
  }

  .email-box {
    margin-top: 14px;
    background: white;
    border-radius: 999px;
    padding: 12px 14px 12px 18px;
    color: var(--muted);
    display: flex;
    justify-content: space-between;
    box-shadow: 0 12px 30px rgba(8,41,79,.08);
  }

  .email-box span {
    color: white;
    background: var(--purple);
    border-radius: 999px;
    padding: 7px 14px;
    font-weight: 800;
  }

  .copyright {
    padding: 20px 6%;
    color: var(--navy);
    background: white;
    font-size: 14px;
  }

  @media (max-width: 900px) {
    .site-header {
      min-height: auto;
      flex-direction: column;
      gap: 18px;
    }

    nav {
      flex-wrap: wrap;
      justify-content: center;
      gap: 14px;
    }

    .hero {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      padding: 54px 7%;
      text-align: center;
    }

    .line { margin: auto; }

    .hero-image {
      border-bottom-left-radius: 0;
      height: 380px;
    }

    .mission, .cards, footer {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .mission-mark { margin: auto; }

    blockquote {
      border-left: none;
      padding-left: 0;
    }

    .cta {
      flex-direction: column;
      text-align: center;
      padding: 44px 26px;
    }

    .hero-leaf,
    .mission-butterfly,
    .footer-butterfly {
      display: none;
    }
  }
</style>
