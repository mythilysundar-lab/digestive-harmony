---
---

<html lang="en">
  <head>
    <title>Digestive Harmony | Advancing Hope for IBD</title>
    <meta name="description" content="Digestive Harmony supports individuals and families affected by IBD through education, awareness, support, and research." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <body>
    <header class="site-header">
      <a class="logo-wrap" href="/">
        <img src="/logo.png" alt="Digestive Harmony logo" />
      </a>

      <nav>
        <a class="active" href="/">Home</a>
        <a href="/about">About</a>
        <a href="/resources">Resources</a>
        <a href="/get-involved">Get Involved</a>
        <a href="/contact">Contact</a>
        <a class="donate" href="/donate">Donate</a>
      </nav>
    </header>

    <main>
      <section class="hero">
<img class="decor decor-butterfly hero-butterfly" src="/butterfly-icon.png" alt="" />
<img class="decor decor-leaf hero-leaf" src="/leaf-pattern.png" alt="" />
        <div class="butterfly b1"></div>
        <div class="butterfly b2"></div>

        <div class="hero-copy">
          <p class="eyebrow">Awareness | Support | Research</p>
          <h1>Advancing Hope for IBD</h1>
          <div class="line"></div>
          <p>
            Helping patients and families navigate digestive conditions through trusted
            education, community, and compassion.
          </p>

          <div class="buttons">
            <a href="/about">Our Mission</a>
            <a class="outline" href="/resources">Explore Resources</a>
          </div>
        </div>

        <div class="hero-image">
          <img src="/hero-family.png" alt="Family support for digestive health" />
        </div>
      </section>

      <section class="mission">
        <div class="mission-mark">DH</div>

        <div>
          <h2>Our Mission</h2>
          <p>
            To improve the lives of those affected by inflammatory bowel disease
            through education, support, advocacy, and research.
          </p>
        </div>

        <blockquote>
          You are not alone.<br />
          We are in this together.
        </blockquote>
      </section>

      <section class="focus">
        <h2>Our Focus</h2>
        <div class="small-line"></div>
        <p class="section-intro">
          We believe education can reduce fear, improve confidence, and help people
          take meaningful steps toward better digestive wellness.
        </p>

        <div class="cards">
          <article>
            <div class="circle">01</div>
            <h3>Digestive Disorders</h3>
            <p>Educational resources on IBD, Crohn's disease, ulcerative colitis, IBS, GERD, and celiac disease.</p>
          </article>

          <article>
            <div class="circle">02</div>
            <h3>Nutrition & Lifestyle</h3>
            <p>Practical guidance for gut-friendly food choices, wellness habits, and daily digestive support.</p>
          </article>

          <article>
            <div class="circle">03</div>
            <h3>Patient Education</h3>
            <p>Clear articles, guides, and resources designed to make digestive health easier to understand.</p>
          </article>

          <article>
            <div class="circle">04</div>
            <h3>Community Support</h3>
            <p>Helping patients, caregivers, and families feel connected, informed, and supported.</p>
          </article>
        </div>
      </section>

      <section class="cta">
        <div class="cta-art"></div>
        <div>
          <h2>Building a healthier, more informed community.</h2>
          <p>
            Whether you are a patient, caregiver, volunteer, or healthcare advocate,
            Digestive Harmony welcomes you.
          </p>
        </div>
        <a href="/get-involved">Get Involved</a>
      </section>
    </main>

    <footer>
      <div>
        <img src="/logo.png" alt="Digestive Harmony logo" />
        <p>A world where everyone affected by IBD can live well and thrive.</p>
      </div>

      <div>
        <h4>Quick Links</h4>
        <a href="/about">About Us</a>
        <a href="/resources">Resources</a>
        <a href="/get-involved">Get Involved</a>
        <a href="/contact">Contact Us</a>
      </div>

      <div>
        <h4>Resources</h4>
        <a href="/resources">IBD Basics</a>
        <a href="/resources">Nutrition</a>
        <a href="/resources">Patient Education</a>
        <a href="/resources">Support & Community</a>
      </div>

      <div>
        <h4>Stay Connected</h4>
        <p>Subscribe for updates, resources, and ways to get involved.</p>
        <div class="email-box">Your email address <span>Submit</span></div>
      </div>
    </footer>

    <div class="copyright">
      &copy; 2026 Digestive Harmony. All rights reserved.
    </div>
  </body>
</html>

<style>
  :root {
    --navy: #08294f;
    --purple: #6e42c1;
    --teal: #0698a8;
    --light-teal: #eefcfd;
    --light-purple: #f5efff;
    --text: #102542;
    --muted: #52647a;
    --white: #ffffff;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: "Inter", Arial, sans-serif;
    color: var(--text);
    background: white;
  }

  a {
    text-decoration: none;
  }

  h1,
  h2 {
    font-family: "Cormorant Garamond", Georgia, serif;
  }

  .site-header {
    min-height: 112px;
    padding: 14px 5.5%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(255,255,255,.96);
    box-shadow: 0 8px 28px rgba(8, 41, 79, 0.06);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .logo-wrap img {
    width: 220px;
    display: block;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 28px;
    font-weight: 700;
  }

  nav a {
    color: var(--navy);
  }

  nav .active {
    color: var(--purple);
    border-bottom: 3px solid var(--purple);
    padding-bottom: 8px;
  }

  .donate {
    color: white !important;
    padding: 14px 24px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--purple), var(--teal));
  }

  .hero {
    position: relative;
    display: grid;
    grid-template-columns: 0.92fr 1.08fr;
    align-items: center;
    min-height: 590px;
    overflow: hidden;
    background:
      radial-gradient(circle at 10% 78%, rgba(110, 66, 193, 0.16), transparent 28%),
      radial-gradient(circle at 92% 18%, rgba(6, 152, 168, 0.15), transparent 32%),
      linear-gradient(135deg, #ffffff 0%, #fbf7ff 45%, #ecfbfc 100%);
  }

  .hero::after {
    content: "";
    position: absolute;
    left: -8%;
    bottom: -90px;
    width: 58%;
    height: 170px;
    background: rgba(110, 66, 193, 0.12);
    border-radius: 50%;
    transform: rotate(5deg);
  }

  .hero-copy {
    padding: 74px 6% 74px 11%;
    z-index: 2;
  }

  .eyebrow {
    color: var(--purple);
    font-size: 15px;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(58px, 6.5vw, 88px);
    line-height: 0.98;
    margin: 20px 0 16px;
    color: var(--navy);
  }

  .line,
  .small-line {
    width: 76px;
    height: 4px;
    border-radius: 99px;
    background: linear-gradient(90deg, var(--purple), var(--teal));
  }

  .hero-copy p:not(.eyebrow) {
    max-width: 570px;
    font-size: 21px;
    line-height: 1.65;
  }

  .buttons {
    margin-top: 30px;
  }

  .buttons a {
    display: inline-block;
    padding: 15px 28px;
    border-radius: 999px;
    color: white;
    font-weight: 800;
    background: linear-gradient(135deg, var(--purple), var(--teal));
    margin-right: 14px;
    box-shadow: 0 14px 30px rgba(6, 152, 168, .18);
  }

  .buttons .outline {
    color: var(--teal);
    background: white;
    border: 2px solid var(--teal);
    box-shadow: none;
  }

  .hero-image {
    height: 100%;
    overflow: hidden;
    border-bottom-left-radius: 110px;
    box-shadow: -20px 20px 70px rgba(8,41,79,.08);
    z-index: 1;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .butterfly {
    position: absolute;
    width: 64px;
    height: 46px;
    opacity: .18;
    z-index: 3;
  }

  .butterfly::before,
  .butterfly::after {
    content: "";
    position: absolute;
    width: 34px;
    height: 44px;
    border: 3px solid var(--purple);
    border-radius: 60% 40% 60% 40%;
    background: rgba(255,255,255,.35);
  }

  .butterfly::after {
    left: 30px;
    border-color: var(--teal);
    transform: scaleX(-1);
  }

  .b1 {
    right: 7%;
    top: 80px;
    transform: rotate(15deg);
  }

  .b2 {
    right: 15%;
    bottom: 80px;
    transform: rotate(-12deg) scale(.75);
  }

  .mission {
    display: grid;
    grid-template-columns: 130px 1.35fr 1fr;
    align-items: center;
    gap: 36px;
    padding: 48px 8%;
    background: linear-gradient(135deg, #fbf8ff, #effdff);
  }

  .mission-mark {
    width: 105px;
    height: 105px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: white;
    color: var(--teal);
    font-weight: 900;
    font-size: 28px;
    box-shadow: 0 16px 40px rgba(110, 66, 193, 0.14);
  }

  .mission h2,
  .focus h2 {
    font-size: 40px;
    margin: 0 0 14px;
    color: var(--navy);
  }

  .mission p {
    line-height: 1.7;
    font-size: 17px;
    margin: 0;
  }

  blockquote {
    margin: 0;
    padding-left: 38px;
    border-left: 1px solid rgba(8, 41, 79, 0.16);
    color: var(--teal);
    font-size: 24px;
    font-style: italic;
    line-height: 1.6;
    font-family: Georgia, serif;
  }

  .focus {
    text-align: center;
    padding: 62px 6% 78px;
    background: white;
  }

  .focus .small-line {
    margin: 12px auto 18px;
  }

  .section-intro {
    max-width: 720px;
    margin: 0 auto 42px;
    line-height: 1.7;
    font-size: 17px;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 26px;
  }

  article {
    background: white;
    border-radius: 26px;
    padding: 40px 28px;
    box-shadow: 0 20px 48px rgba(8, 41, 79, 0.08);
    border: 1px solid #eef1f7;
    transition: transform .3s ease, box-shadow .3s ease;
  }

  article:hover {
    transform: translateY(-7px);
    box-shadow: 0 26px 60px rgba(8, 41, 79, 0.12);
  }

  .circle {
    width: 82px;
    height: 82px;
    margin: 0 auto 22px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 23px;
    font-weight: 900;
    color: var(--purple);
    background: linear-gradient(135deg, var(--light-purple), var(--light-teal));
  }

  article h3 {
    font-size: 21px;
    color: var(--navy);
    margin-bottom: 14px;
  }

  article p {
    line-height: 1.65;
  }

  .cta {
    position: relative;
    margin: 14px 6% 76px;
    padding: 60px;
    border-radius: 32px;
    color: white;
    background:
      radial-gradient(circle at 85% 35%, rgba(255,255,255,.13), transparent 28%),
      linear-gradient(135deg, var(--purple), var(--teal));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 36px;
    box-shadow: 0 24px 54px rgba(8, 41, 79, 0.16);
    overflow: hidden;
  }

  .cta-art {
    position: absolute;
    right: 34px;
    bottom: -35px;
    width: 160px;
    height: 160px;
    border: 2px solid rgba(255,255,255,.18);
    border-radius: 50%;
  }

  .cta h2 {
    font-size: 42px;
    line-height: 1.05;
    margin: 0 0 14px;
    font-family: "Cormorant Garamond", Georgia, serif;
  }

  .cta p {
    font-size: 17px;
    line-height: 1.6;
    max-width: 660px;
  }

  .cta a {
    background: white;
    color: var(--purple);
    padding: 17px 36px;
    border-radius: 999px;
    font-weight: 900;
    white-space: nowrap;
    z-index: 2;
  }

  footer {
    background: #f8f5ff;
    padding: 48px 6%;
    display: grid;
    grid-template-columns: 1.25fr 1fr 1fr 1.15fr;
    gap: 40px;
  }

  footer img {
    width: 185px;
  }

  footer h4 {
    margin: 0 0 16px;
    color: var(--navy);
  }

  footer a {
    display: block;
    color: var(--text);
    margin: 10px 0;
  }

  footer p {
    color: var(--muted);
    line-height: 1.6;
  }

  .email-box {
    margin-top: 14px;
    background: white;
    border-radius: 999px;
    padding: 12px 14px 12px 18px;
    color: var(--muted);
    display: flex;
    justify-content: space-between;
    box-shadow: 0 12px 30px rgba(8,41,79,.08);
  }

  .email-box span {
    color: white;
    background: var(--purple);
    border-radius: 999px;
    padding: 7px 14px;
    font-weight: 800;
  }

  .copyright {
    padding: 20px 6%;
    color: var(--navy);
    background: white;
    font-size: 14px;
  }

  @media (max-width: 900px) {
    .site-header {
      min-height: auto;
      flex-direction: column;
      gap: 18px;
    }

    nav {
      flex-wrap: wrap;
      justify-content: center;
      gap: 14px;
    }

    .hero {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      padding: 52px 7%;
      text-align: center;
    }

    .line {
      margin: auto;
    }

    .hero-image {
      border-bottom-left-radius: 0;
      height: 380px;
    }

    .mission,
    .cards,
    footer {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .mission-mark {
      margin: auto;
    }

    blockquote {
      border-left: none;
      padding-left: 0;
    }

    .cta {
      flex-direction: column;
      text-align: center;
      padding: 42px 26px;
    }
  }
</style>
