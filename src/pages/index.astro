---
---

<html lang="en">
  <head>
    <title>Digestive Harmony | Advancing Hope for IBD</title>
    <meta name="description" content="Digestive Harmony advances hope for IBD through awareness, support, research, education, and community." />
  </head>

  <body>
    <header class="topbar">
      <div>Advancing Hope for IBD</div>
      <nav>
        <a href="#">Patient Resources</a>
        <a href="#">News & Events</a>
        <a href="#">Contact</a>
      </nav>
    </header>

    <header class="main-header">
      <a href="/" class="brand">
        <img src="/logo.png" alt="Digestive Harmony logo" />
      </a>

      <nav class="main-nav">
        <a href="#">About Us</a>
        <a href="#">Understanding IBD</a>
        <a href="#">Resources</a>
        <a href="#">Get Involved</a>
        <a class="donate" href="#">Donate</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-text">
          <h1>Advancing Hope for IBD</h1>
          <p>
            Supporting individuals and families affected by <strong>Crohn's disease</strong>
            and <strong>Ulcerative Colitis</strong> through education, advocacy,
            community, and research.
          </p>
          <div class="buttons">
            <a href="#">Learn More</a>
            <a href="#" class="secondary">Get Involved</a>
          </div>
        </div>

        <div class="hero-image">
          <img src="/hero-family.png" alt="Family support and hope" />
        </div>
      </section>

      <section class="mission-band">
        <div class="mission-icon">🦋</div>
        <div>
          <h2>Our Mission</h2>
          <p>
            To improve the lives of those affected by inflammatory bowel disease
            through education, support, advocacy, and research — empowering
            patients, families, and communities to live fuller, healthier lives.
          </p>
        </div>
        <blockquote>
          “You are not alone.<br />We are in this together.”
        </blockquote>
      </section>

      <section class="section">
        <h2>What We Do</h2>
        <div class="cards">
          <article>
            <div class="icon">🤲</div>
            <h3>Support</h3>
            <p>Providing compassionate support and resources for patients and families.</p>
          </article>

          <article>
            <div class="icon">📖</div>
            <h3>Education</h3>
            <p>Offering evidence-based information to help people understand and manage IBD.</p>
          </article>

          <article>
            <div class="icon">🔬</div>
            <h3>Research</h3>
            <p>Promoting research and awareness for better treatments and future cures.</p>
          </article>

          <article>
            <div class="icon">👥</div>
            <h3>Community</h3>
            <p>Building a strong community where every person feels heard and supported.</p>
          </article>
        </div>
      </section>

      <section class="cta">
        <div>
          <h2>Building a healthier, more informed community.</h2>
          <p>
            Whether you are a patient, caregiver, volunteer, or healthcare advocate,
            Digestive Harmony welcomes you.
          </p>
        </div>
        <a href="#">Get Involved</a>
      </section>
    </main>

    <footer>
      <div>
        <img src="/logo.png" alt="Digestive Harmony logo" />
        <p>A world where everyone affected by IBD can live well and thrive.</p>
      </div>

      <div>
        <h4>Quick Links</h4>
        <a href="#">About Us</a>
        <a href="#">Understanding IBD</a>
        <a href="#">Resources</a>
        <a href="#">Contact</a>
      </div>

      <div>
        <h4>Resources</h4>
        <a href="#">IBD Basics</a>
        <a href="#">Crohn's Disease</a>
        <a href="#">Ulcerative Colitis</a>
        <a href="#">Nutrition</a>
      </div>

      <div>
        <h4>Support Our Work</h4>
        <p>Your generosity helps us continue our mission and bring hope to families.</p>
        <a class="footer-button" href="#">Donate Now</a>
      </div>
    </footer>

    <div class="copyright">
      &copy; 2026 Digestive Harmony. All rights reserved.
    </div>
  </body>
</html>

<style>
  :root {
    --navy: #06264a;
    --purple: #7a4bd8;
    --lavender: #efe7ff;
    --teal: #0697a6;
    --aqua: #e9fbfd;
    --white: #ffffff;
    --text: #13243f;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    color: var(--text);
    background: #ffffff;
  }

  a {
    text-decoration: none;
  }

  .topbar {
    background: var(--navy);
    color: white;
    padding: 12px 6%;
    display: flex;
    justify-content: space-between;
    font-size: 14px;
  }

  .topbar nav a {
    color: white;
    margin-left: 28px;
  }

  .main-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 22px 6%;
    background: white;
    box-shadow: 0 8px 24px rgba(6, 38, 74, 0.08);
  }

  .brand img {
    width: 230px;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 34px;
  }

  .main-nav a {
    color: var(--navy);
    font-weight: 700;
  }

  .donate {
    background: linear-gradient(135deg, var(--purple), var(--teal));
    color: white !important;
    padding: 14px 26px;
    border-radius: 999px;
  }

  .hero {
    display: grid;
    grid-template-columns: 1fr 1.25fr;
    min-height: 560px;
    background: linear-gradient(135deg, #ffffff, var(--aqua));
    overflow: hidden;
  }

  .hero-text {
    padding: 80px 0 80px 11%;
    align-self: center;
    z-index: 2;
  }

  h1 {
    font-size: clamp(48px, 6vw, 76px);
    line-height: 1.05;
    color: var(--navy);
    margin: 0 0 28px;
  }

  .hero-text p {
    font-size: 22px;
    line-height: 1.65;
    max-width: 620px;
  }

  .buttons {
    margin-top: 34px;
  }

  .buttons a {
    display: inline-block;
    background: var(--navy);
    color: white;
    padding: 16px 30px;
    border-radius: 999px;
    font-weight: 800;
    margin-right: 14px;
  }

  .buttons .secondary {
    background: linear-gradient(135deg, var(--purple), var(--teal));
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mission-band {
    display: grid;
    grid-template-columns: 140px 1.4fr 1fr;
    gap: 34px;
    align-items: center;
    padding: 48px 8%;
    background: linear-gradient(135deg, #fbf8ff, #f0fdff);
  }

  .mission-icon {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 48px;
    background: white;
    box-shadow: 0 10px 30px rgba(122, 75, 216, 0.14);
  }

  .mission-band h2,
  .section h2 {
    color: var(--navy);
    font-size: 38px;
    margin: 0 0 16px;
  }

  .mission-band p {
    font-size: 18px;
    line-height: 1.7;
  }

  blockquote {
    color: var(--teal);
    font-size: 26px;
    font-style: italic;
    line-height: 1.5;
    border-left: 1px solid #d5d9e5;
    padding-left: 42px;
  }

  .section {
    padding: 58px 6% 70px;
    text-align: center;
  }

  .cards {
    margin-top: 40px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }

  article {
    background: white;
    padding: 34px 24px;
    border-radius: 22px;
    box-shadow: 0 14px 34px rgba(6, 38, 74, 0.09);
    border: 1px solid #eef1f7;
  }

  .icon {
    width: 76px;
    height: 76px;
    margin: 0 auto 18px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, var(--lavender), var(--aqua));
    font-size: 32px;
  }

  article h3 {
    color: var(--teal);
    font-size: 24px;
  }

  article p {
    line-height: 1.65;
  }

  .cta {
    margin: 20px 6% 70px;
    padding: 56px;
    border-radius: 32px;
    color: white;
    background: linear-gradient(135deg, var(--purple), var(--teal));
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .cta h2 {
    font-size: 36px;
    margin: 0 0 14px;
  }

  .cta p {
    font-size: 18px;
    max-width: 650px;
    line-height: 1.6;
  }

  .cta a {
    background: white;
    color: var(--purple);
    padding: 16px 32px;
    border-radius: 999px;
    font-weight: 900;
  }

  footer {
    background: var(--navy);
    color: white;
    padding: 58px 6%;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.2fr;
    gap: 44px;
  }

  footer img {
    width: 190px;
    background: white;
    padding: 8px;
    border-radius: 10px;
  }

  footer a {
    display: block;
    color: white;
    margin: 10px 0;
  }

  .footer-button {
    display: inline-block;
    margin-top: 12px;
    background: var(--purple);
    padding: 13px 22px;
    border-radius: 999px;
  }

  .copyright {
    background: #031d3a;
    color: white;
    padding: 18px 6%;
    font-size: 14px;
  }

  @media (max-width: 900px) {
    .topbar,
    .main-header,
    .main-nav,
    .cta {
      flex-direction: column;
      text-align: center;
    }

    .main-nav {
      margin-top: 20px;
      gap: 16px;
      flex-wrap: wrap;
    }

    .hero {
      grid-template-columns: 1fr;
    }

    .hero-text {
      padding: 56px 7%;
      text-align: center;
    }

    .mission-band,
    .cards,
    footer {
      grid-template-columns: 1fr;
      text-align: center;
    }

    blockquote {
      border-left: none;
      padding-left: 0;
    }
  }
</style>
