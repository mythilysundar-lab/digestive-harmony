---
---

<html lang="en">
  <head>
    <title>Digestive Harmony | Advancing Hope for IBD</title>
    <meta
      name="description"
      content="Digestive Harmony is a nonprofit organization advancing hope for IBD through awareness, support, research, education, and community."
    />
  </head>

  <body>
    <header>
      <a class="brand" href="/">
        <img src="/logo.png" alt="Digestive Harmony logo" />
      </a>

      <nav>
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/blog">Resources</a>
        <a href="/contact">Contact</a>
        <a class="donate" href="/contact">Get Involved</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-text">
          <p class="eyebrow">Awareness | Support | Research</p>
          <h1>Advancing Hope for IBD</h1>
          <div class="accent"></div>
          <p>
            Digestive Harmony is a nonprofit organization dedicated to education,
            awareness, and support for individuals and families affected by
            inflammatory bowel disease and digestive conditions.
          </p>

          <div class="buttons">
            <a href="/about">Our Mission</a>
            <a class="secondary" href="/blog">Explore Resources</a>
          </div>
        </div>

        <div class="hero-logo">
          <img src="/logo.png" alt="Digestive Harmony logo" />
        </div>
      </section>

      <section class="intro">
        <h2>Our Focus</h2>
        <div class="small-accent"></div>
        <p>
          We believe education can reduce fear, improve confidence, and help
          people take meaningful steps toward better digestive wellness.
        </p>
      </section>

      <section class="cards">
        <article>
          <div class="icon">01</div>
          <h3>Digestive Disorders</h3>
          <p>
            Educational resources on IBD, Crohn's disease, ulcerative colitis,
            IBS, GERD, celiac disease, and more.
          </p>
        </article>

        <article>
          <div class="icon">02</div>
          <h3>Nutrition & Lifestyle</h3>
          <p>
            Practical guidance for gut-friendly food choices, wellness habits,
            and daily digestive support.
          </p>
        </article>

        <article>
          <div class="icon">03</div>
          <h3>Patient Education</h3>
          <p>
            Clear articles, guides, and resources designed to make digestive
            health easier to understand.
          </p>
        </article>

        <article>
          <div class="icon">04</div>
          <h3>Community Support</h3>
          <p>
            Helping patients, caregivers, and families feel connected,
            informed, and supported.
          </p>
        </article>
      </section>

      <section class="cta">
        <div>
          <h2>Building a healthier, more informed community.</h2>
          <p>
            Whether you are a patient, caregiver, volunteer, or healthcare
            advocate, Digestive Harmony welcomes you.
          </p>
        </div>
        <a href="/contact">Get Involved</a>
      </section>
    </main>

    <footer>
      <img src="/logo.png" alt="Digestive Harmony logo" />
      <p>© 2026 Digestive Harmony. All rights reserved.</p>
    </footer>
  </body>
</html>

<style>
  :root {
    --purple: #6b3bbd;
    --deep-purple: #4c258f;
    --teal: #008f9c;
    --dark-teal: #075b65;
    --navy: #152646;
    --soft-lavender: #f4ecff;
    --soft-teal: #e9fbfc;
    --white: #ffffff;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    color: var(--navy);
    background: linear-gradient(135deg, #fbf8ff, #f3feff);
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 6%;
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 8px 24px rgba(37, 33, 72, 0.08);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .brand img {
    width: 260px;
    max-width: 42vw;
    display: block;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  nav a {
    color: var(--navy);
    text-decoration: none;
    font-weight: 700;
  }

  nav a:first-child {
    color: var(--purple);
  }

  .donate {
    padding: 13px 22px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--purple), var(--teal));
    color: white;
  }

  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 42px;
    padding: 85px 6% 95px;
    background:
      radial-gradient(circle at 18% 80%, rgba(107, 59, 189, 0.18), transparent 28%),
      radial-gradient(circle at 90% 22%, rgba(0, 143, 156, 0.18), transparent 30%),
      linear-gradient(135deg, #fbf8ff 0%, #ffffff 45%, #ebfcff 100%);
    overflow: hidden;
  }

  .eyebrow {
    color: var(--deep-purple);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 16px;
    font-weight: 900;
  }

  h1 {
    font-size: clamp(48px, 6vw, 82px);
    line-height: 1.03;
    margin: 18px 0 16px;
    background: linear-gradient(135deg, var(--deep-purple), var(--teal));
    -webkit-background-clip: text;
    color: transparent;
  }

  .accent,
  .small-accent {
    width: 80px;
    height: 4px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--purple), var(--teal));
    margin: 18px 0 28px;
  }

  .hero-text p {
    max-width: 620px;
    font-size: 20px;
    line-height: 1.75;
  }

  .buttons {
    margin-top: 34px;
  }

  .buttons a,
  .cta a {
    display: inline-block;
    padding: 15px 28px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--purple), var(--teal));
    color: white;
    text-decoration: none;
    font-weight: 900;
    margin-right: 14px;
    box-shadow: 0 12px 26px rgba(0, 143, 156, 0.2);
  }

  .buttons .secondary {
    background: white;
    color: var(--teal);
    border: 2px solid var(--teal);
    box-shadow: none;
  }

  .hero-logo {
    text-align: center;
  }

  .hero-logo img {
    max-width: 620px;
    width: 100%;
    filter: drop-shadow(0 18px 35px rgba(76, 37, 143, 0.16));
  }

  .intro {
    text-align: center;
    padding: 60px 6% 20px;
    background: white;
  }

  .intro h2 {
    font-size: 44px;
    margin: 0;
    color: var(--navy);
  }

  .small-accent {
    margin: 16px auto 24px;
  }

  .intro p {
    max-width: 780px;
    margin: auto;
    font-size: 19px;
    line-height: 1.7;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding: 42px 6% 70px;
    background: white;
  }

  article {
    text-align: center;
    background: white;
    border-radius: 26px;
    padding: 36px 26px;
    box-shadow: 0 18px 42px rgba(21, 38, 70, 0.09);
    border: 1px solid rgba(107, 59, 189, 0.08);
  }

  .icon {
    width: 82px;
    height: 82px;
    margin: 0 auto 18px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 24px;
    font-weight: 900;
    color: var(--deep-purple);
    background: linear-gradient(135deg, var(--soft-lavender), var(--soft-teal));
  }

  article h3 {
    color: var(--navy);
    font-size: 22px;
    margin-bottom: 14px;
  }

  article p {
    line-height: 1.65;
    font-size: 16px;
  }

  .cta {
    margin: 30px 6% 70px;
    padding: 54px;
    border-radius: 32px;
    color: white;
    background:
      radial-gradient(circle at 15% 30%, rgba(255, 255, 255, 0.16), transparent 24%),
      linear-gradient(135deg, var(--purple), var(--teal));
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 30px;
    box-shadow: 0 18px 45px rgba(76, 37, 143, 0.18);
  }

  .cta h2 {
    font-size: 38px;
    margin: 0 0 12px;
  }

  .cta p {
    max-width: 650px;
    font-size: 18px;
    line-height: 1.6;
  }

  .cta a {
    background: white;
    color: var(--deep-purple);
    box-shadow: none;
    white-space: nowrap;
  }

  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 28px 6%;
    background: white;
    color: #5b6276;
    border-top: 1px solid rgba(21, 38, 70, 0.08);
  }

  footer img {
    width: 190px;
  }

  @media (max-width: 950px) {
    header,
    nav,
    footer,
    .cta {
      flex-direction: column;
      text-align: center;
    }

    nav {
      gap: 14px;
      margin-top: 16px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .hero {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 60px 6%;
    }

    .accent {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-text p {
      margin-left: auto;
      margin-right: auto;
    }

    .cards {
      grid-template-columns: 1fr;
    }

    .brand img {
      max-width: 80vw;
    }
  }
</style>
