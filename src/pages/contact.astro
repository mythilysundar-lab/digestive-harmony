<style>

:root{

--purple:#6e42c1;

--teal:#0698a8;

--navy:#08294f;

}

*{

box-sizing:border-box;

}

body{

margin:0;

font-family:Inter,sans-serif;

color:#223;

background:white;

}

.header{

display:flex;

justify-content:space-between;

align-items:center;

padding:18px 6%;

box-shadow:0 6px 25px rgba(0,0,0,.05);

background:white;

}

.logo{

width:190px;

}

nav{

display:flex;

gap:28px;

align-items:center;

font-weight:600;

}

nav a{

color:var(--navy);

text-decoration:none;

}

.active{

color:var(--purple);

}

.donate{

padding:12px 24px;

border-radius:999px;

background:linear-gradient(135deg,var(--purple),var(--teal));

color:white;

}

.hero{

padding:90px 10%;

text-align:center;

background:linear-gradient(135deg,#fff,#f9f5ff,#eefcff);

}

.hero h1{

font-family:"Cormorant Garamond",serif;

font-size:70px;

margin-bottom:20px;

color:var(--navy);

}

.hero p{

max-width:720px;

margin:auto;

font-size:20px;

line-height:1.8;

}

.contact-grid{

display:grid;

grid-template-columns:repeat(3,1fr);

gap:30px;

padding:80px 8%;

}

.card{

background:white;

padding:40px;

border-radius:24px;

box-shadow:0 15px 40px rgba(0,0,0,.08);

text-align:center;

}

.card h2{

font-family:"Cormorant Garamond",serif;

font-size:34px;

color:var(--navy);

}

.card p{

line-height:1.8;

}

.message{

margin:40px auto 80px;

max-width:900px;

padding:70px;

text-align:center;

border-radius:30px;

background:linear-gradient(135deg,var(--purple),var(--teal));

color:white;

}

.message h2{

font-family:"Cormorant Garamond",serif;

font-size:46px;

margin-top:0;

}

.message a{

display:inline-block;

margin-top:25px;

padding:16px 34px;

background:white;

color:var(--purple);

border-radius:999px;

font-weight:700;

text-decoration:none;

}

footer{

padding:60px;

text-align:center;

background:#f7f5ff;

}

.footer-logo{

width:180px;

margin-bottom:15px;

}

@media(max-width:900px){

.header{

flex-direction:column;

gap:20px;

}

nav{

flex-wrap:wrap;

justify-content:center;

}

.contact-grid{

grid-template-columns:1fr;

}

.hero h1{

font-size:54px;

}

.message{

margin:30px;

padding:40px;

}

}

</style>
