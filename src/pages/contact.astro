
---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact Us | Digestive Harmony"
  description="Contact Digestive Harmony for questions, partnerships, volunteer opportunities, or general inquiries."
  active="contact"
>
  <main>
    <section class="contact-hero">
      <img class="decor hero-leaf" src="/leaf-pattern.png" alt="" />
      <img class="decor hero-butterfly" src="/butterfly-icon.png" alt="" />

      <p class="eyebrow">Contact Us</p>
      <h1>We would love to hear from you.</h1>
      <p>
        Whether you have a question, want to volunteer, partner with us, or simply say hello,
        Digestive Harmony is here to connect.
      </p>
    </section>

    <section class="contact-cards">
      <article>
        <h2>General Inquiries</h2>
        <p>Questions about Digestive Harmony, resources, or our mission.</p>
        <a href="mailto:info@digestiveharmony.org">info@digestiveharmony.org</a>
      </article>

      <article>
        <h2>Volunteer</h2>
        <p>Interested in supporting our work or helping the IBD community?</p>
        <a href="mailto:volunteer@digestiveharmony.org">volunteer@digestiveharmony.org</a>
      </article>

      <article>
        <h2>Partnerships</h2>
        <p>For schools, healthcare groups, nonprofits, or community partners.</p>
        <a href="mailto:partners@digestiveharmony.org">partners@digestiveharmony.org</a>
      </article>
    </section>

    <section class="contact-cta">
      <div>
        <p class="cta-label">Let’s connect</p>
        <h2>Have a question or idea?</h2>
        <p>Email us and we’ll respond as soon as possible.</p>
      </div>

      <a href="mailto:info@digestiveharmony.org">Email Us</a>
    </section>
  </main>
</Layout>

<style>
  .contact-hero {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding: 105px 8% 115px;
    background:
      radial-gradient(circle at 12% 78%, rgba(110,66,193,.14), transparent 30%),
      radial-gradient(circle at 88% 20%, rgba(6,152,168,.12), transparent 32%),
      linear-gradient(135deg, #ffffff, #fbf7ff 45%, #ecfbfc);
  }

  .contact-hero h1 {
    font-size: clamp(56px, 7vw, 88px);
    line-height: .98;
    color: var(--navy);
    margin: 14px 0 20px;
  }

  .contact-hero p:last-child {
    max-width: 780px;
    margin: 0 auto;
    font-size: 21px;
    line-height: 1.7;
  }

  .eyebrow {
    color: var(--purple);
    text-transform: uppercase;
    letter-spacing: .2em;
    font-weight: 900;
    font-size: 14px;
  }

  .hero-leaf {
    width: 360px;
    left: -90px;
    bottom: -70px;
    opacity: .08;
  }

  .hero-butterfly {
    width: 88px;
    right: 8%;
    top: 80px;
    opacity: .18;
  }

  .contact-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    padding: 80px 6%;
  }

  .contact-cards article {
    background: white;
    border-radius: 28px;
    padding: 42px 30px;
    text-align: center;
    box-shadow: 0 15px 40px rgba(0,0,0,.08);
    border: 1px solid #edf1f7;
  }

  .contact-cards h2 {
    font-size: 34px;
    color: var(--navy);
    margin: 0 0 14px;
  }

  .contact-cards p {
    color: var(--muted);
    line-height: 1.7;
  }

  .contact-cards a {
    color: var(--teal);
    font-weight: 800;
  }

  .contact-cta {
    position: relative;
    margin: 20px 6% 80px;
    padding: 60px;
    border-radius: 34px;
    color: white;
    background:
      radial-gradient(circle at 86% 35%, rgba(255,255,255,.14), transparent 28%),
      linear-gradient(135deg, var(--purple), var(--teal));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 36px;
    box-shadow: 0 24px 54px rgba(8,41,79,.16);
  }

  .cta-label {
    text-transform: uppercase;
    letter-spacing: .16em;
    font-size: 13px;
    font-weight: 900;
    opacity: .9;
  }

  .contact-cta h2 {
    font-size: 44px;
    margin: 0 0 12px;
  }

  .contact-cta p {
    line-height: 1.6;
  }

  .contact-cta a {
    background: white;
    color: var(--purple);
    padding: 17px 36px;
    border-radius: 999px;
    font-weight: 900;
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .contact-cards {
      grid-template-columns: 1fr;
    }

    .contact-cta {
      flex-direction: column;
      text-align: center;
      padding: 44px 26px;
    }

    .hero-leaf,
    .hero-butterfly {
      display: none;
    }
  }
</style>


