
---
const {
  title = "Digestive Harmony | Advancing Hope for IBD",
  description = "Digestive Harmony supports individuals and families affected by IBD through education, awareness, support, and research.",
  active = ""
} = Astro.props;
---

<html lang="en">
  <head>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <img src="/logo.png" alt="Digestive Harmony logo" />
      </a>

      <nav class="site-nav">
        <a class={active === "home" ? "active" : ""} href="/">Home</a>
        <a class={active === "about" ? "active" : ""} href="/about">About</a>
        <a class={active === "resources" ? "active" : ""} href="/resources">Resources</a>
        <a class={active === "get-involved" ? "active" : ""} href="/get-involved">Get Involved</a>
        <a class={active === "contact" ? "active" : ""} href="/contact">Contact</a>
        <a class="donate" href="/donate">Donate</a>
      </nav>
    </header>

    <slot />

    <footer>
      <img class="decor footer-butterfly" src="/butterfly-icon.png" alt="" />

      <div>
        <img class="footer-logo" src="/logo.png" alt="Digestive Harmony logo" />
        <p>A world where everyone affected by IBD can live well and thrive.</p>
      </div>

      <div>
        <h4>Quick Links</h4>
        <a href="/about">About Us</a>
        <a href="/resources">Resources</a>
        <a href="/get-involved">Get Involved</a>
        <a href="/contact">Contact Us</a>
      </div>

      <div>
        <h4>Resources</h4>
        <a href="/resources">IBD Basics</a>
        <a href="/resources">Nutrition</a>
        <a href="/resources">Patient Education</a>
        <a href="/resources">Support & Community</a>
      </div>

      <div>
        <h4>Stay Connected</h4>
        <p>Subscribe for updates, resources, and ways to get involved.</p>
        <div class="email-box">Your email address <span>Submit</span></div>
      </div>
    </footer>

    <div class="copyright">
      &copy; 2026 Digestive Harmony. All rights reserved.
    </div>
  </body>
</html>

<style is:global>
  :root {
    --navy: #08294f;
    --purple: #6e42c1;
    --teal: #0698a8;
    --light-teal: #eefcfd;
    --light-purple: #f5efff;
    --text: #102542;
    --muted: #52647a;
    --white: #ffffff;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: "Inter", Arial, sans-serif;
    color: var(--text);
    background: white;
  }

  a {
    text-decoration: none;
  }

  h1,
  h2,
  h3 {
    font-family: "Cormorant Garamond", Georgia, serif;
  }

  .site-header {
    min-height: 104px;
    padding: 12px 5.5%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(255,255,255,.97);
    box-shadow: 0 8px 28px rgba(8, 41, 79, 0.06);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .brand img {
    width: 205px;
    max-height: 86px;
    object-fit: contain;
    display: block;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 26px;
    font-weight: 700;
    font-size: 15px;
  }

  .site-nav a {
    color: var(--navy);
    position: relative;
  }

  .site-nav .active {
    color: var(--purple);
  }

  .site-nav .active::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -9px;
    width: 100%;
    height: 3px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--purple), var(--teal));
  }

  .donate {
    color: white !important;
    padding: 13px 24px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--purple), var(--teal));
    box-shadow: 0 12px 26px rgba(6, 152, 168, 0.18);
  }

  .decor {
    position: absolute;
    pointer-events: none;
    user-select: none;
  }

  footer {
    position: relative;
    overflow: hidden;
    background: #f8f5ff;
    padding: 54px 6%;
    display: grid;
    grid-template-columns: 1.25fr 1fr 1fr 1.15fr;
    gap: 40px;
  }

  .footer-logo {
    width: 185px;
  }

  footer h4 {
    margin: 0 0 16px;
    color: var(--navy);
  }

  footer a {
    display: block;
    color: var(--text);
    margin: 10px 0;
  }

  footer p {
    color: var(--muted);
    line-height: 1.6;
  }

  .footer-butterfly {
    width: 78px;
    right: 5%;
    bottom: 24px;
    opacity: .12;
  }

  .email-box {
    margin-top: 14px;
    background: white;
    border-radius: 999px;
    padding: 12px 14px 12px 18px;
    color: var(--muted);
    display: flex;
    justify-content: space-between;
    box-shadow: 0 12px 30px rgba(8,41,79,.08);
  }

  .email-box span {
    color: white;
    background: var(--purple);
    border-radius: 999px;
    padding: 7px 14px;
    font-weight: 800;
  }

  .copyright {
    padding: 20px 6%;
    color: var(--navy);
    background: white;
    font-size: 14px;
  }

  @media (max-width: 900px) {
    .site-header {
      min-height: auto;
      flex-direction: column;
      gap: 18px;
      padding: 16px 6%;
    }

    .brand img {
      width: 180px;
      max-height: 80px;
    }

    .site-nav {
      flex-wrap: wrap;
      justify-content: center;
      gap: 14px;
      font-size: 14px;
    }

    footer {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-butterfly {
      display: none;
    }
  }
</style>
